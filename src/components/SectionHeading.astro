---
interface Props {
  label: string;
  title: string;
  description?: string;
}

const { label, title, description } = Astro.props;
---
<header class="space-y-3">
  <p class="blueprint-label">{label}</p>
  <div class="max-w-3xl space-y-3">
    <h2 class="text-2xl font-semibold text-(--blueprint-text) sm:text-3xl">{title}</h2>
    {description && <p class="blueprint-muted text-sm leading-6 sm:text-base sm:leading-7">{description}</p>}
  </div>
</header>
