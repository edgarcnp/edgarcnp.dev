---
import { type ActionVariant, ACTION_CLASSES } from '../lib/types';

interface Props {
  href: string;
  external?: boolean;
  variant?: ActionVariant;
}

const { href, external, variant = 'secondary' } = Astro.props;
---
<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class={ACTION_CLASSES[variant]}
>
  <slot />
</a>
