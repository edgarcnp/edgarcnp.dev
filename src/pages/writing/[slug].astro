---
import Layout from '../../layouts/Layout.astro';
import TechTag from '../../components/shared/TechTag.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;
const post = await getEntry('writing', slug!);

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);
---
<Layout title={post.data.title}>
  <article class="mx-auto max-w-3xl space-y-8">
    <header class="blueprint-frame space-y-5 p-5 sm:p-6">
      <a
        href="/writing"
        class="inline-flex rounded-sm font-mono text-xs font-semibold uppercase tracking-wide text-(--blueprint-accent) underline-offset-4 outline-none hover:underline focus-visible:ring-2 focus-visible:ring-(--blueprint-accent)"
      >
        Back to writing
      </a>
      <div class="space-y-3">
        <div class="blueprint-label flex flex-wrap gap-x-4 gap-y-1">
          <span class="whitespace-nowrap">Published {post.data.published}</span>
          <span class="whitespace-nowrap">Updated {post.data.updated}</span>
        </div>
        <h1 class="text-3xl font-semibold text-(--blueprint-text) sm:text-4xl">{post.data.title}</h1>
        <p class="text-base leading-7 text-(--blueprint-muted)">{post.data.summary}</p>
      </div>
      <ul class="flex flex-wrap gap-2">
        {post.data.tags.map((tag) => (
          <li><TechTag label={tag} /></li>
        ))}
      </ul>
    </header>
    <div class="markdown-body">
      <Content />
    </div>
  </article>
</Layout>
