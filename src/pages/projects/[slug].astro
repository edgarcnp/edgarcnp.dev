---
import Layout from '../../layouts/Layout.astro';
import TechTag from '../../components/shared/TechTag.astro';
import StatusBadge from '../../components/shared/StatusBadge.astro';
import LinkAction from '../../components/ui/astro/LinkAction.astro';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

const project = await getEntry('projects', slug);

if (!project) {
  return Astro.redirect('/404');
}

const { Content } = await render(project);
---
<Layout title={project.data.title}>
  <article class="mx-auto max-w-3xl space-y-8">
    <header class="blueprint-frame space-y-5 p-5 sm:p-6">
      <a
        href="/projects"
        class="inline-flex rounded-sm font-mono text-xs font-semibold uppercase tracking-wide text-(--blueprint-accent) underline-offset-4 outline-none hover:underline focus-visible:ring-2 focus-visible:ring-(--blueprint-accent)"
      >
        Back to projects
      </a>
      <div class="space-y-3">
        <div class="blueprint-label flex flex-wrap gap-x-4 gap-y-1">
          <span class="whitespace-nowrap">Published {project.data.published}</span>
          <span class="whitespace-nowrap">Updated {project.data.updated}</span>
        </div>
        <div class="flex items-start justify-between gap-4">
          <h1 class="text-3xl font-semibold text-(--blueprint-text) sm:text-4xl">{project.data.title}</h1>
          <StatusBadge status={project.data.status} />
        </div>
        <p class="text-base leading-7 text-(--blueprint-muted)">{project.data.summary}</p>
      </div>
      <ul class="flex flex-wrap gap-2">
        {project.data.technologies.map((tech) => (
          <li><TechTag label={tech} /></li>
        ))}
      </ul>
      {project.data.links.length > 0 && (
        <div class="flex flex-wrap gap-3">
          {project.data.links.map((link) => (
            <LinkAction href={link.href} external={link.external} variant="secondary">{link.label}</LinkAction>
          ))}
        </div>
      )}
    </header>
    <div class="markdown-body">
      <Content />
    </div>
  </article>
</Layout>
