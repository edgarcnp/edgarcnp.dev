{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every day"],
  "packageRules": [
    {
      "matchPackagePatterns": ["^@solidjs/", "^solid-js$"],
      "groupName": "SolidJS"
    },
    {
      "matchPackagePatterns": ["^vite$", "^@tailwindcss/vite$"],
      "groupName": "Vite"
    },
    {
      "matchPackagePatterns": ["^tailwindcss$"],
      "groupName": "Tailwind"
    }
  ]
}
